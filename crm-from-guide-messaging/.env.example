# ONODE / OASIS — ChatBridge (Babelfish). Server-side only; not exposed to the browser.
OASIS_API_URL=https://api.oasisweb4.com

# guide-telegram-bridge — operator dashboard → Telegram DMs (POST /api/send). Server-side only.
# Use the same secret as BRIDGE_ADMIN_TOKEN in guide-telegram-bridge/.env
GUIDE_TELEGRAM_BRIDGE_URL=http://127.0.0.1:3847
GUIDE_TELEGRAM_BRIDGE_ADMIN_TOKEN=

# Optional: The Union union-api for WhatsApp (Compose / Conversations / Automations)
NEXT_PUBLIC_UNION_API_URL=http://localhost:3001
