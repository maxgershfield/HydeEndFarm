PORT=8788
# CORS origins (comma-separated), or * for dev
CORS_ORIGIN=*

# --- Single default client (when no clients.json) ---
PARTNER_ID=hyde_end
PARTNER_DISPLAY_NAME=Hyde End Vineyard
OASIS_API_URL=https://api.oasisweb4.com
# Service account JWT for save-holon + metadata queries (Wizard or delegated role)
OASIS_SERVICE_JWT=
PARTNER_REGISTRY_TAG=hyde_end_v1

# oasis = persist holons via OASIS; file = local JSON (no JWT required)
REGISTRY_BACKEND=file

# Optional: path to JSON client list (see config/clients.example.json)
# PARTNER_CLIENTS_PATH=./config/clients.json

# Optional operator endpoints (seed-demo, etc.) — generate e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PARTNER_ADMIN_KEY=
