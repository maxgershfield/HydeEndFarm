# Hyde End Cellar Door (forked from The Union Q2P storefront)
# Copy to .env.local

# Optional: absolute URL to syndicate passport (footer/header links)
NEXT_PUBLIC_HYDE_PASSPORT_URL=https://hydeendfarm.vercel.app/passport.html

# Site metadata
SITE_NAME=Hyde End Cellar Door
NEXT_PUBLIC_VERCEL_URL=http://localhost:3000

# OASIS (optional — cart modal quest discounts)
NEXT_PUBLIC_OASIS_ONODE_URL=http://localhost:5004
NEXT_PUBLIC_OASIS_STAR_API_URL=http://localhost:50564

# Medusa — only needed if you disable HYDE_MARKETPLACE in lib/medusa/index.ts
# NEXT_PUBLIC_MEDUSA_BACKEND_API=http://localhost:9000
# MEDUSA_API_KEY=
# MEDUSA_REVALIDATION_SECRET=
